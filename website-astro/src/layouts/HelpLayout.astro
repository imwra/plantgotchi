---
import BaseLayout from "./BaseLayout.astro";
import SiteNav from "../components/SiteNav";
import { getLocaleFromPath, useTranslations, loadContent } from "../i18n";

interface Props {
  title: string;
  description?: string;
  category?: string;
}

const { title, description, category } = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const prefix = locale === "en" ? "/en" : "";
const helpIndex = await loadContent(locale, "help-index") as any;
---

<BaseLayout title={`${title} - Plantgotchi ${t("help.breadcrumb.help")}`} description={description}>
  <SiteNav
    client:load
    locale={locale}
    currentPath={Astro.url.pathname}
    labels={{
      home: t("nav.home"),
      garden: t("nav.garden"),
      help: t("nav.help"),
      admin: t("nav.admin"),
      login: t("nav.login"),
      logout: t("nav.logout"),
      toggleMenu: t("nav.toggleMenu"),
      langPtbr: t("lang.pt-br"),
      langEn: t("lang.en"),
      langCurrentPtbr: t("lang.current.pt-br"),
      langCurrentEn: t("lang.current.en"),
    }}
  />

  <div class="max-w-6xl mx-auto px-4 py-8">
    {/* Breadcrumb */}
    <nav class="text-xs text-pixel-gray mb-6">
      <a href={`${prefix}/`} class="hover:text-green-dark transition-colors">{t("help.breadcrumb.home")}</a>
      <span class="mx-2">/</span>
      <a href={`${prefix}/help`} class="hover:text-green-dark transition-colors">{t("help.breadcrumb.help")}</a>
      {category && (
        <>
          <span class="mx-2">/</span>
          <span class="text-pixel-black">{category}</span>
        </>
      )}
    </nav>

    <div class="flex flex-col lg:flex-row gap-8">
      {/* Sidebar */}
      <aside class="lg:w-64 shrink-0">
        <div class="lg:sticky lg:top-20">
          <h3 class="pixel-font text-[10px] text-green-dark mb-4">{t("help.sidebar.title")}</h3>
          {helpIndex.categories.map((cat: any) => (
            <div class="mb-4">
              <p class="text-xs font-bold text-pixel-black mb-1">
                {cat.emoji} {cat.name}
              </p>
              <ul class="space-y-1">
                {cat.articles.map((article: any) => (
                  <li>
                    <a
                      href={`${prefix}/help/${article.slug}`}
                      class="text-xs text-pixel-gray hover:text-green-dark transition-colors block py-0.5 pl-5"
                    >
                      {article.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </aside>

      {/* Main content */}
      <main class="flex-1 min-w-0">
        <article class="bg-white/60 p-6 sm:p-8 pixel-border">
          <h1 class="pixel-font text-sm sm:text-base text-green-dark mb-6">{title}</h1>
          <div class="prose prose-sm max-w-none [&_h2]:pixel-font [&_h2]:text-[11px] [&_h2]:text-pixel-black [&_h2]:mt-8 [&_h2]:mb-3 [&_h3]:font-bold [&_h3]:text-pixel-black [&_h3]:mt-6 [&_h3]:mb-2 [&_p]:text-pixel-gray [&_p]:leading-relaxed [&_p]:mb-4 [&_ul]:text-pixel-gray [&_ul]:mb-4 [&_ul]:space-y-1 [&_li]:leading-relaxed [&_ol]:text-pixel-gray [&_ol]:mb-4 [&_ol]:space-y-1 [&_code]:bg-cream-dark [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-green-dark [&_code]:text-xs [&_a]:text-green-plant [&_a]:underline [&_a]:hover:text-green-dark [&_table]:w-full [&_table]:text-xs [&_th]:text-left [&_th]:p-2 [&_th]:bg-cream-dark [&_th]:font-bold [&_td]:p-2 [&_td]:border-t [&_td]:border-cream-dark">
            <slot />
          </div>
        </article>
      </main>
    </div>
  </div>
</BaseLayout>
