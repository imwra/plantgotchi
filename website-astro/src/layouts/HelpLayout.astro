---
import BaseLayout from "./BaseLayout.astro";
import SiteNav from "../components/SiteNav";

interface Props {
  title: string;
  description?: string;
  category?: string;
}

const { title, description, category } = Astro.props;

const categories = [
  {
    name: "Getting Started",
    emoji: "🌱",
    articles: [
      { title: "What is Plantgotchi?", href: "/help/what-is-plantgotchi" },
      { title: "Quick Start Guide", href: "/help/quick-start" },
      { title: "Creating Your Account", href: "/help/creating-account" },
    ],
  },
  {
    name: "Sensors & Hardware",
    emoji: "📡",
    articles: [
      { title: "Sensor Types", href: "/help/sensor-types" },
      { title: "Sensor Setup", href: "/help/sensor-setup" },
      { title: "Battery & Charging", href: "/help/sensor-battery" },
    ],
  },
  {
    name: "Mobile Apps",
    emoji: "📱",
    articles: [
      { title: "iOS App", href: "/help/ios-app" },
      { title: "Android App", href: "/help/android-app" },
      { title: "Syncing Your Data", href: "/help/syncing-data" },
    ],
  },
  {
    name: "Plant Care",
    emoji: "🌿",
    articles: [
      { title: "Adding Plants", href: "/help/adding-plants" },
      { title: "Reading Sensor Data", href: "/help/reading-data" },
      { title: "AI Recommendations", href: "/help/ai-recommendations" },
    ],
  },
  {
    name: "Troubleshooting",
    emoji: "🔧",
    articles: [
      { title: "Sensor Not Connecting", href: "/help/sensor-not-connecting" },
      { title: "Data Not Syncing", href: "/help/data-not-syncing" },
      { title: "FAQ", href: "/help/faq" },
    ],
  },
];
---

<BaseLayout title={`${title} - Plantgotchi Help`} description={description}>
  <SiteNav client:load />

  <div class="max-w-6xl mx-auto px-4 py-8">
    {/* Breadcrumb */}
    <nav class="text-xs text-pixel-gray mb-6">
      <a href="/" class="hover:text-green-dark transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/help" class="hover:text-green-dark transition-colors">Help</a>
      {category && (
        <>
          <span class="mx-2">/</span>
          <span class="text-pixel-black">{category}</span>
        </>
      )}
    </nav>

    <div class="flex flex-col lg:flex-row gap-8">
      {/* Sidebar */}
      <aside class="lg:w-64 shrink-0">
        <div class="lg:sticky lg:top-20">
          <h3 class="pixel-font text-[10px] text-green-dark mb-4">Help Topics</h3>
          {categories.map((cat) => (
            <div class="mb-4">
              <p class="text-xs font-bold text-pixel-black mb-1">
                {cat.emoji} {cat.name}
              </p>
              <ul class="space-y-1">
                {cat.articles.map((article) => (
                  <li>
                    <a
                      href={article.href}
                      class="text-xs text-pixel-gray hover:text-green-dark transition-colors block py-0.5 pl-5"
                    >
                      {article.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </aside>

      {/* Main content */}
      <main class="flex-1 min-w-0">
        <article class="bg-white/60 p-6 sm:p-8 pixel-border">
          <h1 class="pixel-font text-sm sm:text-base text-green-dark mb-6">{title}</h1>
          <div class="prose prose-sm max-w-none [&_h2]:pixel-font [&_h2]:text-[11px] [&_h2]:text-pixel-black [&_h2]:mt-8 [&_h2]:mb-3 [&_h3]:font-bold [&_h3]:text-pixel-black [&_h3]:mt-6 [&_h3]:mb-2 [&_p]:text-pixel-gray [&_p]:leading-relaxed [&_p]:mb-4 [&_ul]:text-pixel-gray [&_ul]:mb-4 [&_ul]:space-y-1 [&_li]:leading-relaxed [&_ol]:text-pixel-gray [&_ol]:mb-4 [&_ol]:space-y-1 [&_code]:bg-cream-dark [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-green-dark [&_code]:text-xs [&_a]:text-green-plant [&_a]:underline [&_a]:hover:text-green-dark [&_table]:w-full [&_table]:text-xs [&_th]:text-left [&_th]:p-2 [&_th]:bg-cream-dark [&_th]:font-bold [&_td]:p-2 [&_td]:border-t [&_td]:border-cream-dark">
            <slot />
          </div>
        </article>
      </main>
    </div>
  </div>
</BaseLayout>
