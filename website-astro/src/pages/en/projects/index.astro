---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProjectListPage from "../../../components/ui/organisms/ProjectListPage";
import { getSession } from "../../../lib/auth";
import { getLocaleFromPath, useTranslations } from "../../../i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const session = await getSession(Astro.request);
if (!session) {
  return Astro.redirect(locale === "en" ? "/en/login" : "/login");
}

if ((session.user as any).role !== "admin") {
  return Astro.redirect(locale === "en" ? "/en/garden" : "/garden");
}

const userName = session.user.name || session.user.email;
---

<BaseLayout title={t("projects.title")}>
  <ProjectListPage
    client:load
    userName={userName}
    locale={locale}
    navLabels={{
      home: t("nav.home"),
      garden: t("nav.garden"),
      chat: t("nav.chat"),
      help: t("nav.help"),
      admin: t("nav.admin"),
      projects: t("nav.projects"),
      login: t("nav.login"),
      logout: t("nav.logout"),
      toggleMenu: t("nav.toggleMenu"),
      langPtbr: t("lang.pt-br"),
      langEn: t("lang.en"),
      langCurrentPtbr: t("lang.current.pt-br"),
      langCurrentEn: t("lang.current.en"),
    }}
    labels={{
      title: t("projects.title"),
      newProject: t("projects.newProject"),
      name: t("projects.name"),
      description: t("projects.description"),
      create: t("projects.create"),
      cancel: t("projects.cancel"),
      issues: t("projects.issues"),
      members: t("projects.members"),
      noProjects: t("projects.noProjects"),
      createFirst: t("projects.createFirst"),
    }}
  />
</BaseLayout>
