            <div class="border-[3px] border-pixel-black rounded-[20px] bg-cream-dark p-2.5 relative overflow-hidden">
              <div class="mx-auto w-16 h-2.5 bg-pixel-black rounded-full mb-2"></div>
              <div class="bg-cream rounded-lg overflow-hidden">
                <div class="p-2">
                  <div class="pixel-font text-[5px] text-green-dark mb-2">Alerts</div>
                  <div class="space-y-1.5">
                    {content.notifications.map((n: any, ni: number) => (
                      <div class="flex gap-1.5 items-start bg-cream-dark rounded p-1">
                        <div class={`w-1.5 h-1.5 rounded-full ${NOTIFICATION_ICONS[ni]} shrink-0 mt-0.5`}></div>
                        <div class="flex-1 min-w-0">
                          <div class="flex justify-between">
                            <span class="pixel-font text-[3px] text-pixel-black truncate">{n.title}</span>
                            <span class="pixel-font text-[2.5px] text-pixel-gray shrink-0 ml-1">{n.time}</span>
                          </div>
                          <span class="text-[3px] text-pixel-gray">{n.desc}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
              <div class="mx-auto w-12 h-1 bg-pixel-black/30 rounded-full mt-2"></div>
            </div>
            <p class="pixel-font text-[7px] text-center text-green-dark mt-2">Notifications</p>
          </div>

          <!-- 5: Sensor Pairing -->
          <div class="w-full max-w-[200px] mx-auto">
            <div class="border-[3px] border-pixel-black rounded-[20px] bg-cream-dark p-2.5 relative overflow-hidden">
              <div class="mx-auto w-16 h-2.5 bg-pixel-black rounded-full mb-2"></div>
              <div class="bg-cream rounded-lg overflow-hidden">
                <div class="p-2">
                  <div class="pixel-font text-[5px] text-green-dark mb-2 text-center">Add Sensor</div>
                  <div class="flex justify-center mb-2">
                    <div class="w-12 h-12 rounded-full border-2 border-green-plant/30 flex items-center justify-center relative">
                      <div class="w-8 h-8 rounded-full border-2 border-green-plant/50 flex items-center justify-center">
                        <div class="w-4 h-4 rounded-full bg-green-plant/20 flex items-center justify-center">
                          <div class="w-2 h-2 bg-green-plant rounded-full animate-pulse-glow"></div>
                        </div>
                      </div>
                    </div>
                  </div>
                  <p class="pixel-font text-[4px] text-center text-pixel-gray mb-2">Scanning for sensors...</p>
                  <div class="space-y-1">
                    {FOUND_SENSORS.map((sensor, i) => (
                      <div class="flex items-center gap-1.5 bg-cream-dark rounded p-1.5">
                        <div class={`w-2 h-2 rounded-full ${i === 0 ? "bg-green-plant animate-pulse-glow" : "bg-pixel-gray/30"}`}></div>
                        <span class="pixel-font text-[3.5px] text-pixel-black flex-1">{sensor}</span>
                        <span class="pixel-font text-[3px] text-cream bg-green-plant px-1.5 py-0.5 rounded">Pair</span>
                      </div>
                    ))}
                  </div>
                  <p class="text-[3px] text-pixel-gray text-center mt-2">Place sensor in pairing mode (hold button 3s)</p>
                </div>
              </div>
              <div class="mx-auto w-12 h-1 bg-pixel-black/30 rounded-full mt-2"></div>
            </div>
            <p class="pixel-font text-[7px] text-center text-green-dark mt-2">Pair Sensor</p>
          </div>

          <!-- 6: Settings -->
          <div class="w-full max-w-[200px] mx-auto">
            <div class="border-[3px] border-pixel-black rounded-[20px] bg-cream-dark p-2.5 relative overflow-hidden">
              <div class="mx-auto w-16 h-2.5 bg-pixel-black rounded-full mb-2"></div>
              <div class="bg-cream rounded-lg overflow-hidden">
                <div class="p-2">
                  <div class="pixel-font text-[5px] text-green-dark mb-2">Settings</div>
                  <div class="space-y-1">
                    {content.settingsGroups.map((group: any) => (
                      <div>
                        <span class="pixel-font text-[3px] text-pixel-gray">{group.section}</span>
                        <div class="bg-cream-dark rounded mt-0.5">
                          {group.items.map((item: string, i: number) => (
                            <div class={`flex items-center justify-between px-1.5 py-1 ${i < group.items.length - 1 ? "border-b border-cream" : ""}`}>
                              <span class="text-[3.5px] text-pixel-black">{item}</span>
                              <div class="w-4 h-2 bg-green-plant rounded-full relative">
                                <div class="absolute right-0.5 top-0.5 w-1 h-1 bg-white rounded-full"></div>
                              </div>
                            </div>
                          ))}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
              <div class="mx-auto w-12 h-1 bg-pixel-black/30 rounded-full mt-2"></div>
            </div>
            <p class="pixel-font text-[7px] text-center text-green-dark mt-2">Settings</p>
          </div>
        </div>

        <!-- Coming to App Store badge -->
        <div class="flex flex-col items-center mt-12 gap-3">
          <div class="bg-pixel-black text-cream rounded-xl px-6 py-3 flex items-center gap-3">
            <div class="flex flex-col items-center">
              <svg class="w-6 h-6 text-cream" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
              </svg>
            </div>
            <div>
              <span class="pixel-font text-[6px] text-cream/60 block">Coming 2026</span>
              <span class="pixel-font text-[9px] text-cream">Download on the App Store</span>
            </div>
          </div>
          <p class="text-xs text-pixel-gray">Native iOS app. Built with SwiftUI.</p>
        </div>
      </div>
    </section>

    <!-- PRICING / BUNDLES -->
    <section id="pricing" class="bg-cream-dark py-16 sm:py-24 relative scanlines">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="pixel-font text-sm sm:text-base text-center text-green-dark mb-4">
          {content.sections.preOrderBundles}
        </h2>
        <p class="text-center text-pixel-gray mb-14 max-w-md mx-auto">
          Save more when you bundle.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {content.bundles.map((b: any, i: number) => (
            <div
              class={`bg-cream rounded-lg pixel-border p-6 flex flex-col items-center text-center gap-3 ${
                i === 1 ? "ring-2 ring-green-plant" : ""
              }`}
            >
              {i === 1 && (
                <span class="pixel-font text-[7px] bg-green-plant text-cream px-2 py-0.5 -mt-3 mb-1">
                  BEST VALUE
                </span>
              )}
              <h3 class="pixel-font text-[10px] text-pixel-black">{b.name}</h3>
              <span class="pixel-font text-xl text-green-dark">{b.price}</span>
              <p class="text-sm text-pixel-gray">{b.contents}</p>
              <a
                href="#"
                class="mt-auto pixel-font text-[8px] bg-green-plant text-cream px-5 py-2.5 pixel-border hover:bg-green-dark transition-colors"
              >
                Pre-order
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- OPEN SOURCE -->
    <section class="py-12 sm:py-16">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <div class="bg-cream-dark rounded-lg pixel-border p-8 relative overflow-hidden scanlines">
          <h2 class="pixel-font text-[10px] sm:text-xs text-green-dark mb-4">
            {content.openSource.title}
          </h2>
          <p class="text-sm text-pixel-gray mb-4 max-w-md mx-auto">
            Forked from{" "}
            <a
              href="https://github.com/rbaron/b-parasite"
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent-blue underline hover:text-accent-blue/80"
            >
              b-parasite
            </a>{" "}
            by rbaron. Schematics, firmware, and enclosures are all open.
          </p>
          <div class="inline-flex items-center gap-2 bg-cream px-4 py-2 rounded-full pixel-border">
            <span class="pixel-font text-[7px] text-pixel-gray">LICENSE</span>
            <span class="pixel-font text-[8px] text-green-dark">CC BY-SA 4.0</span>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-pixel-black text-cream py-12">
      <div class="max-w-5xl mx-auto px-4">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">
          <div>
            <h3 class="pixel-font text-[10px] text-green-light mb-4">Stay in the loop</h3>
            <p class="text-sm text-cream/60 mb-4">
              Get updates on launch dates, new sensors, and plant care tips.
            </p>
            <form class="flex gap-2">
              <input
                type="email"
                placeholder="you@email.com"
                aria-label="Email address"
                class="flex-1 bg-pixel-gray/30 text-cream text-sm px-3 py-2 rounded-sm border border-pixel-gray/40 placeholder:text-cream/30 focus:outline-none focus:border-green-plant"
              />
              <button
                type="submit"
                class="pixel-font text-[8px] bg-green-plant text-cream px-4 py-2 hover:bg-green-dark transition-colors"
              >
                Join
              </button>
            </form>
          </div>

          <div class="sm:text-center">
            <h3 class="pixel-font text-[10px] text-green-light mb-4">Links</h3>
            <ul class="space-y-2 text-sm text-cream/60">
              <li><a href="#how-it-works" class="hover:text-cream transition-colors">How It Works</a></li>
              <li><a href="#products" class="hover:text-cream transition-colors">Products</a></li>
              <li><a href="#pricing" class="hover:text-cream transition-colors">Pricing</a></li>
              <li><a href="#app" class="hover:text-cream transition-colors">App</a></li>
            </ul>
          </div>

          <div class="sm:text-right">
            <h3 class="pixel-font text-[10px] text-green-light mb-4">Follow us</h3>
            <div class="flex sm:justify-end gap-4">
              {["GitHub", "Twitter", "Discord"].map((s) => (
                <a
                  href="#"
                  class="text-sm text-cream/60 hover:text-cream transition-colors"
                >
                  {s}
                </a>
              ))}
            </div>
          </div>
        </div>

        <div class="border-t border-pixel-gray/30 mt-10 pt-6 text-center">
          <p class="pixel-font text-[8px] text-cream/40">
            {content.footer.tagline} &bull; Plantgotchi &copy; 2026
          </p>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>
