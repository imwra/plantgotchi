---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav";
import { getLocaleFromPath, useTranslations, loadContent } from "../../i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const content = await loadContent(locale, "landing") as any;
const prefix = locale === "en" ? "/en" : "";

const PRODUCT_COLORS = ["bg-green-light", "bg-green-plant", "bg-accent-blue", "bg-accent-purple"];
const SETUP_ICONS = ["hub", "solo", "parent"];

const GARDEN_PLANTS = [
  { name: "Fern-ando", type: "Boston Fern", moisture: 72, light: 45, temp: 22, hp: 92, status: "happy", battery: 85 },
  { name: "Aloe There", type: "Aloe Vera", moisture: 31, light: 78, temp: 24, hp: 68, status: "thirsty", battery: 62 },
  { name: "Leaf Erikson", type: "Monstera", moisture: 58, light: 32, temp: 21, hp: 87, status: "happy", battery: 94 },
  { name: "Cact-Jack", type: "Barrel Cactus", moisture: 15, light: 92, temp: 26, hp: 95, status: "happy", battery: 78 },
  { name: "Herb Alpert", type: "Basil", moisture: 44, light: 55, temp: 23, hp: 73, status: "needs-light", battery: 41 },
  { name: "Ivy League", type: "Pothos", moisture: 63, light: 28, temp: 20, hp: 81, status: "happy", battery: 99 },
];

const MOISTURE_CHART = [60, 55, 70, 65, 45, 80, 67];
const DETAIL_CHART = [60, 55, 70, 65, 45, 80, 72];

const FOUND_SENSORS = ["Plantgotchi-A3F2", "Plantgotchi-B7E1"];

const DETAIL_STATS = [
  { label: "MOISTURE", value: "72%", color: "bg-accent-blue", pct: 72 },
  { label: "LIGHT", value: "45%", color: "bg-accent-orange", pct: 45 },
  { label: "TEMP", value: "22\u00B0C", color: "bg-accent-red", pct: 55 },
  { label: "HP", value: "92%", color: "bg-green-plant", pct: 92 },
];

const VENT_LINES = [0, 1, 2, 3, 4, 5, 6];
const LED_DOTS = [0, 1, 2];

const NOTIFICATION_ICONS = ["bg-accent-orange", "bg-accent-blue", "bg-green-plant", "bg-accent-red", "bg-accent-blue"];
---

<BaseLayout title={content.meta.title} description={content.meta.description}>
  <div class="min-h-screen bg-cream text-pixel-black">
    <!-- STICKY NAV -->
    <SiteNav
      client:load
      locale={locale}
      currentPath={Astro.url.pathname}
      labels={{
        home: t("nav.home"),
        garden: t("nav.garden"),
        help: t("nav.help"),
        admin: t("nav.admin"),
        login: t("nav.login"),
        logout: t("nav.logout"),
        toggleMenu: t("nav.toggleMenu"),
        langPtbr: t("lang.pt-br"),
        langEn: t("lang.en"),
        langCurrentPtbr: t("lang.current.pt-br"),
        langCurrentEn: t("lang.current.en"),
      }}
    />

    <!-- HERO -->
    <section class="relative overflow-hidden">
      <div class="max-w-5xl mx-auto px-4 pt-16 pb-20 sm:pt-24 sm:pb-28 flex flex-col items-center text-center gap-8">
        <!-- Pixel plant -->
        <div class="relative h-40 w-40 flex items-end justify-center">
          <div class="animate-bounce-plant relative" aria-hidden="true">
            <!-- Pot -->
            <div class="mx-auto w-20 h-10 bg-brown relative">
              <div class="absolute -top-1 -left-1 w-22 h-3 bg-brown-light" style="width: calc(100% + 8px); left: -4px;"></div>
              <div class="absolute bottom-0 left-1 right-1 h-1 bg-brown-light opacity-40"></div>
            </div>
            <!-- Soil -->
            <div class="mx-auto w-20 h-2 bg-brown-light opacity-60 -mt-px"></div>
            <!-- Stem -->
            <div class="mx-auto w-2 h-14 bg-green-dark -mt-2 relative z-10"></div>
            <!-- Leaves -->
            <div class="absolute left-1/2 -translate-x-1/2 bottom-[56px]">
              <!-- center leaf -->
              <div class="w-10 h-10 bg-green-plant rounded-sm pixel-border mx-auto -mb-2 relative">
                <div class="absolute inset-1 bg-green-light opacity-40 rounded-sm"></div>
              </div>
              <!-- left leaf -->
              <div class="absolute -left-8 top-4 w-8 h-6 bg-green-plant rounded-sm rotate-[-20deg]">
                <div class="absolute inset-1 bg-green-light opacity-30 rounded-sm"></div>
              </div>
              <!-- right leaf -->
              <div class="absolute -right-8 top-4 w-8 h-6 bg-green-plant rounded-sm rotate-[20deg]">
                <div class="absolute inset-1 bg-green-light opacity-30 rounded-sm"></div>
              </div>
            </div>
            <!-- Face -->
            <div class="absolute left-1/2 -translate-x-1/2 bottom-[68px] flex gap-2">
              <div class="w-2 h-2 bg-pixel-black rounded-full"></div>
              <div class="w-2 h-2 bg-pixel-black rounded-full"></div>
            </div>
            <div class="absolute left-1/2 -translate-x-1/2 bottom-[62px] w-3 h-1.5 border-b-2 border-pixel-black rounded-b-full"></div>
          </div>
        </div>

        <h1 class="pixel-font text-lg sm:text-2xl md:text-3xl leading-relaxed text-green-dark max-w-3xl">
          {content.hero.heading[0]} {content.hero.heading[1]}<br />
          {content.hero.heading[2]} {content.hero.heading[3]}
        </h1>

        <p class="text-pixel-gray text-base sm:text-lg max-w-xl">
          {content.hero.tagline}
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="#pricing"
            class="pixel-font text-xs bg-green-plant text-cream px-8 py-4 pixel-border hover:bg-green-dark transition-colors"
          >
            {content.hero.cta}
          </a>
          <a
            href="#how-it-works"
            class="pixel-font text-xs border-2 border-pixel-black text-pixel-black px-8 py-4 hover:bg-cream-dark transition-colors"
          >
            {content.hero.ctaSecondary}
          </a>
        </div>
      </div>

      <!-- decorative dots -->
      <div class="absolute top-8 left-8 w-2 h-2 bg-accent-orange rounded-full animate-pulse-glow"></div>
      <div class="absolute top-20 right-12 w-2 h-2 bg-accent-blue rounded-full animate-pulse-glow"></div>
      <div class="absolute bottom-12 left-16 w-1.5 h-1.5 bg-accent-purple rounded-full animate-pulse-glow"></div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="how-it-works" class="bg-cream-dark py-16 sm:py-24 relative scanlines">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="pixel-font text-sm sm:text-base text-center text-green-dark mb-14">
          {content.howItWorks.title}
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 sm:gap-6">
          <!-- Step 1 -->
          <div class="flex flex-col items-center text-center gap-4">
            <div class="w-20 h-20 bg-cream rounded-lg pixel-border flex items-center justify-center">
              <div class="w-16 h-16 flex items-center justify-center relative">
                <div class="absolute bottom-0 left-0 right-0 h-6 bg-brown rounded-b-lg"></div>
                <div class="w-2 h-10 bg-green-plant relative z-10 animate-bounce-plant"></div>
                <div class="absolute top-1 left-1/2 -translate-x-1/2 text-lg">
                  <span class="pixel-font text-accent-orange text-[10px]">!</span>
                </div>
              </div>
            </div>
            <span class="pixel-font text-[10px] text-accent-orange">{content.howItWorks.steps[0].label}</span>
            <h3 class="pixel-font text-xs text-pixel-black">{content.howItWorks.steps[0].title}</h3>
            <p class="text-pixel-gray text-sm max-w-xs">{content.howItWorks.steps[0].desc}</p>
          </div>

          <!-- Step 2 -->
          <div class="flex flex-col items-center text-center gap-4">
            <div class="w-20 h-20 bg-cream rounded-lg pixel-border flex items-center justify-center">
              <div class="w-16 h-16 flex items-center justify-center relative">
                <div class="flex flex-col items-center gap-1">
                  <div class="w-10 h-1.5 bg-accent-blue rounded-full opacity-40"></div>
                  <div class="w-7 h-1.5 bg-accent-blue rounded-full opacity-60"></div>
                  <div class="w-4 h-1.5 bg-accent-blue rounded-full opacity-80"></div>
                  <div class="w-2 h-2 bg-accent-blue rounded-full animate-pulse-glow"></div>
                </div>
              </div>
            </div>
            <span class="pixel-font text-[10px] text-accent-orange">{content.howItWorks.steps[1].label}</span>
            <h3 class="pixel-font text-xs text-pixel-black">{content.howItWorks.steps[1].title}</h3>
            <p class="text-pixel-gray text-sm max-w-xs">{content.howItWorks.steps[1].desc}</p>
          </div>

          <!-- Step 3 -->
          <div class="flex flex-col items-center text-center gap-4">
            <div class="w-20 h-20 bg-cream rounded-lg pixel-border flex items-center justify-center">
              <div class="w-16 h-16 flex items-center justify-center relative">
                <div class="w-12 h-12 bg-green-plant pixel-border flex flex-col items-center justify-center gap-1">
                  <div class="flex gap-2">
                    <div class="w-1.5 h-1.5 bg-pixel-black rounded-full"></div>
                    <div class="w-1.5 h-1.5 bg-pixel-black rounded-full"></div>
                  </div>
                  <div class="w-4 h-1.5 border-b-2 border-pixel-black rounded-b-full"></div>
                </div>
                <div class="absolute -top-1 -right-1 text-accent-orange pixel-font text-[8px] animate-pulse-glow">*</div>
                <div class="absolute -bottom-1 -left-1 text-accent-orange pixel-font text-[8px] animate-pulse-glow">*</div>
              </div>
            </div>
            <span class="pixel-font text-[10px] text-accent-orange">{content.howItWorks.steps[2].label}</span>
            <h3 class="pixel-font text-xs text-pixel-black">{content.howItWorks.steps[2].title}</h3>
            <p class="text-pixel-gray text-sm max-w-xs">{content.howItWorks.steps[2].desc}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PRODUCT LINEUP -->
    <section id="products" class="py-16 sm:py-24">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="pixel-font text-sm sm:text-base text-center text-green-dark mb-4">
          {content.sections.productLineup}
        </h2>
        <p class="text-center text-pixel-gray mb-14 max-w-lg mx-auto">
          From a tiny soil sensor to a full AI-powered plant hub&nbsp;&mdash; pick what fits your jungle.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {content.products.map((p: any, i: number) => (
            <div
              class="bg-cream-dark rounded-lg pixel-border p-6 flex flex-col items-center text-center gap-4 relative overflow-hidden"
            >
              <div class="flex items-center justify-center" style={`height: ${i === 3 ? 160 : 140}px`}>
                {i === 0 && (
                  <svg viewBox="0 0 140 200" width="140" height="200" class="block mx-auto drop-shadow-lg">
                    <polygon points="64,105 76,105 73,195 67,195" fill="#9E9E9E" />
                    <polygon points="64,105 67,195 65,193 62,105" fill="#757575" />
                    <polygon points="67,195 73,195 70,200 67,200" fill="#616161" />
                    <polygon points="70,18 120,42 70,66 20,42" fill="#A5D6A7" />
                    <polygon points="70,66 120,42 120,90 70,114" fill="#81C784" />
                    <polygon points="70,66 20,42 20,90 70,114" fill="#66BB6A" />
                    <polygon points="70,18 120,42 70,66 20,42" fill="white" fill-opacity="0.15" />
                    <ellipse cx="70" cy="36" rx="6" ry="3.5" fill="#C8E6C9" />
                    <ellipse cx="70" cy="36" rx="4" ry="2.5" fill="#69F0AE">
                      <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite" />
                    </ellipse>
                    <polygon points="78,56 112,43 112,60 78,73" fill="#1B5E20" fill-opacity="0.5" />
                    <polygon points="80,58 110,46 110,58 80,70" fill="#1B5E20" />
                    <rect x="84" y="60" width="3" height="6" fill="#69F0AE" opacity="0.8" transform="skewY(-26)" />
                    <rect x="90" y="57" width="3" height="9" fill="#69F0AE" opacity="0.8" transform="skewY(-26)" />
                    <rect x="96" y="55" width="3" height="7" fill="#69F0AE" opacity="0.6" transform="skewY(-26)" />
                    <g transform="translate(32,72) skewY(26)">
                      <rect x="0" y="0" width="16" height="8" rx="1.5" fill="none" stroke="#2E7D32" stroke-width="1.5" />
                      <rect x="16" y="2" width="2" height="4" rx="0.5" fill="#2E7D32" />
                      <rect x="2" y="2" width="10" height="4" rx="0.5" fill="#69F0AE" opacity="0.7" />
                    </g>
                    <g transform="translate(92, 78)">
                      <circle cx="0" cy="0" r="3.5" fill="#E8F5E9" opacity="0.6" />
                      <path d="M-1.5,1 Q0,-3 1.5,1" fill="none" stroke="#2E7D32" stroke-width="1" />
                    </g>
                    <text x="70" y="12" text-anchor="middle" font-size="7" font-family="'Press Start 2P', monospace" fill="#795548" opacity="0.5">22x15mm</text>
                  </svg>
                )}
                {i === 1 && (
                  <svg viewBox="0 0 140 200" width="140" height="200" class="block mx-auto drop-shadow-lg">
                    <polygon points="64,105 76,105 73,195 67,195" fill="#9E9E9E" />
                    <polygon points="64,105 67,195 65,193 62,105" fill="#757575" />
                    <polygon points="67,195 73,195 70,200 67,200" fill="#616161" />
                    <polygon points="70,18 120,42 70,66 20,42" fill="#66BB6A" />
                    <polygon points="70,66 120,42 120,90 70,114" fill="#4CAF50" />
                    <polygon points="70,66 20,42 20,90 70,114" fill="#388E3C" />
                    <polygon points="70,18 120,42 70,66 20,42" fill="white" fill-opacity="0.15" />
                    <ellipse cx="70" cy="36" rx="6" ry="3.5" fill="#C8E6C9" />
                    <ellipse cx="70" cy="36" rx="4" ry="2.5" fill="#69F0AE">
                      <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite" />
                    </ellipse>
                    <polygon points="78,56 112,43 112,60 78,73" fill="#1B5E20" fill-opacity="0.5" />
                    <polygon points="80,58 110,46 110,58 80,70" fill="#1B5E20" />
                    <rect x="84" y="60" width="3" height="6" fill="#69F0AE" opacity="0.8" transform="skewY(-26)" />
                    <rect x="90" y="57" width="3" height="9" fill="#69F0AE" opacity="0.8" transform="skewY(-26)" />
                    <rect x="96" y="55" width="3" height="7" fill="#69F0AE" opacity="0.6" transform="skewY(-26)" />
                    <g>
                      <rect x="36" y="94" width="14" height="5" rx="2" fill="#424242" transform="skewY(26)" />
                      <rect x="38" y="95" width="10" height="3" rx="1" fill="#616161" transform="skewY(26)" />
                    </g>
                    <g transform="translate(92, 78)">
                      <circle cx="0" cy="0" r="3.5" fill="#E8F5E9" opacity="0.6" />
                      <path d="M-1.5,1 Q0,-3 1.5,1" fill="none" stroke="#2E7D32" stroke-width="1" />
                    </g>
                    <text x="70" y="12" text-anchor="middle" font-size="7" font-family="'Press Start 2P', monospace" fill="#795548" opacity="0.5">28x18mm</text>
                  </svg>
                )}
                {i === 2 && (
                  <svg viewBox="0 0 160 180" width="160" height="180" class="block mx-auto drop-shadow-lg">
                    <polygon points="80,10 140,40 80,70 20,40" fill="#424242" />
                    <polygon points="80,70 140,40 140,110 80,140" fill="#2c2c2c" />
                    <polygon points="80,70 20,40 20,110 80,140" fill="#1a1a1a" />
                    <polygon points="80,10 140,40 80,70 20,40" fill="white" fill-opacity="0.08" />
                    <ellipse cx="108" cy="78" rx="16" ry="18" fill="#1a1a1a" />
                    <ellipse cx="108" cy="78" rx="13" ry="15" fill="#0D47A1" />
                    <ellipse cx="108" cy="78" rx="10" ry="11.5" fill="#1565C0" />
                    <ellipse cx="108" cy="78" rx="6" ry="7" fill="#42A5F5">
                      <animate attributeName="opacity" values="0.8;1;0.8" dur="3s" repeatCount="indefinite" />
                    </ellipse>
                    <ellipse cx="104" cy="73" rx="3" ry="2" fill="white" opacity="0.35" />
                    <ellipse cx="56" cy="35" rx="4" ry="2.5" fill="#c62828" />
                    <ellipse cx="56" cy="35" rx="2.5" ry="1.5" fill="#EF5350">
                      <animate attributeName="opacity" values="1;0.2;1" dur="1.5s" repeatCount="indefinite" />
                    </ellipse>
                    <text x="56" y="30" text-anchor="middle" font-size="5" font-family="'Press Start 2P', monospace" fill="#EF5350" opacity="0.7">REC</text>
                    <polygon points="34,62 50,70 50,82 34,74" fill="#37474F" />
                    <polygon points="36,64 48,71 48,80 36,73" fill="#263238" />
                    <polygon points="20,95 28,99 28,115 20,111" fill="#616161" />
                    <polygon points="28,99 36,95 36,111 28,115" fill="#757575" />
                    <g transform="translate(108, 108)">
                      <circle cx="0" cy="0" r="4" fill="#424242" stroke="#616161" stroke-width="0.5" />
                      <path d="M-2,1.5 Q0,-3 2,1.5" fill="none" stroke="#81C784" stroke-width="1" />
                    </g>
                    <text x="108" y="128" text-anchor="middle" font-size="6" font-family="'Press Start 2P', monospace" fill="#9E9E9E" opacity="0.6">5MP</text>
                    <text x="80" y="6" text-anchor="middle" font-size="7" font-family="'Press Start 2P', monospace" fill="#795548" opacity="0.5">38x32mm</text>
                    <polygon points="74,140 86,140 82,175 78,175" fill="#757575" />
                    <polygon points="74,140 78,175 76,174 72,140" fill="#616161" />
                  </svg>
                )}
                {i === 3 && (
                  <svg viewBox="0 0 200 190" width="200" height="190" class="block mx-auto drop-shadow-lg">
                    <polygon points="100,170 170,140 100,155 30,140" fill="#2E7D32" />
                    <polygon points="100,155 170,140 170,145 100,170" fill="#1B5E20" />
                    <polygon points="100,155 30,140 30,145 100,170" fill="#245828" />
                    <polygon points="100,12 168,46 100,80 32,46" fill="#388E3C" />
                    <polygon points="100,80 168,46 168,130 100,150" fill="#2E7D32" />
                    <polygon points="100,80 32,46 32,130 100,150" fill="#1B5E20" />
                    <polygon points="100,12 168,46 100,80 32,46" fill="white" fill-opacity="0.1" />
                    <polygon points="108,56 158,36 158,85 108,105" fill="#0a0a0a" />
                    <polygon points="110,58 156,39 156,83 110,103" fill="#0D1117" />
                    <polygon points="112,60 154,42 154,46 112,64" fill="#1B5E20" />
                    <rect x="114" y="66" width="5" height="5" fill="#69F0AE" opacity="0.7" transform="skewY(-26)" />
                    <rect x="122" y="63" width="5" height="5" fill="#81C784" opacity="0.7" transform="skewY(-26)" />
                    <rect x="130" y="60" width="5" height="5" fill="#FFB74D" opacity="0.7" transform="skewY(-26)" />
                    <rect x="138" y="57" width="5" height="5" fill="#69F0AE" opacity="0.6" transform="skewY(-26)" />
                    <line x1="114" y1="83" x2="150" y2="69" stroke="#69F0AE" stroke-width="1" opacity="0.5" />
                    <line x1="114" y1="87" x2="150" y2="73" stroke="#42A5F5" stroke-width="1" opacity="0.4" />
                    <rect x="114" y="92" width="20" height="2" fill="#69F0AE" opacity="0.4" transform="skewY(-26)" />
                    <ellipse cx="134" cy="118" rx="10" ry="11" fill="#1a1a1a" />
                    <ellipse cx="134" cy="118" rx="7.5" ry="8.5" fill="#0D47A1" />
                    <ellipse cx="134" cy="118" rx="5" ry="5.5" fill="#42A5F5" opacity="0.8" />
                    <ellipse cx="132" cy="115" rx="2" ry="1.5" fill="white" opacity="0.3" />
                    {VENT_LINES.map((vi) => (
                      <line x1="38" y1={62 + vi * 8} x2="56" y2={70 + vi * 8} stroke="#245828" stroke-width="2.5" opacity="0.5" />
                    ))}
                    <rect x="50" y="18" width="4" height="22" rx="2" fill="#616161" transform="skewY(26) skewX(-10)" />
                    <circle cx="56" cy="16" r="3" fill="#757575" />
                    <path d="M42,12 Q56,2 70,12" fill="none" stroke="#69F0AE" stroke-width="1" opacity="0.5">
                      <animate attributeName="opacity" values="0.5;0.1;0.5" dur="2s" repeatCount="indefinite" />
                    </path>
                    <path d="M46,16 Q56,8 66,16" fill="none" stroke="#69F0AE" stroke-width="1" opacity="0.7">
                      <animate attributeName="opacity" values="0.7;0.2;0.7" dur="2s" begin="0.3s" repeatCount="indefinite" />
                    </path>
                    {LED_DOTS.map((li) => (
                      <ellipse cx={88 + li * 12} cy={30 + li * 6} rx="3" ry="1.8" fill="#69F0AE" opacity={0.6 + li * 0.15}>
                        <animate attributeName="opacity" values={`${0.6 + li * 0.15};0.2;${0.6 + li * 0.15}`} dur="2.5s" begin={`${li * 0.4}s`} repeatCount="indefinite" />
                      </ellipse>
                    ))}
                    <text x="100" y="8" text-anchor="middle" font-size="7" font-family="'Press Start 2P', monospace" fill="#795548" opacity="0.5">62x45mm</text>
                    <text x="48" y="125" font-size="5" font-family="'Press Start 2P', monospace" fill="#A5D6A7" opacity="0.4" transform="skewY(26)">RPi</text>
                  </svg>
                )}
              </div>

              <h3 class="pixel-font text-[10px] text-pixel-black">{p.name}</h3>
              <span class="italic text-pixel-gray text-sm">&ldquo;{p.nickname}&rdquo;</span>
              <span class="pixel-font text-xs text-green-dark">{p.price}</span>

              <ul class="text-sm text-pixel-gray space-y-1 mt-auto">
                {p.specs.map((s: string) => (
                  <li class="flex items-center gap-1.5 justify-center">
                    <span class="w-1.5 h-1.5 bg-green-plant inline-block"></span>
                    {s}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ECOSYSTEM / SETUPS -->
    <section class="bg-cream-dark py-16 sm:py-24 relative scanlines">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="pixel-font text-sm sm:text-base text-center text-green-dark mb-4">
          {content.sections.setupConfigurations}
        </h2>
        <p class="text-center text-pixel-gray mb-14 max-w-md mx-auto">
          Mix and match to fit your space.
