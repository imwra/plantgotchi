---
import BaseLayout from "../../layouts/BaseLayout.astro";
import IssueDetail from "../../components/ui/organisms/IssueDetail";
import { getSession } from "../../lib/auth";
import { getLocaleFromPath, useTranslations } from "../../i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const session = await getSession(Astro.request);
if (!session) {
  return Astro.redirect(locale === "en" ? "/en/login" : "/login");
}

if ((session.user as any).role !== "admin") {
  return Astro.redirect(locale === "en" ? "/en/garden" : "/garden");
}

const { id } = Astro.params;
const userName = session.user.name || session.user.email;
---

<BaseLayout title={t("issues.title")}>
  <IssueDetail
    client:load
    issueId={id!}
    userId={session.user.id}
    userName={userName}
    locale={locale}
    navLabels={{
      home: t("nav.home"),
      garden: t("nav.garden"),
      chat: t("nav.chat"),
      help: t("nav.help"),
      admin: t("nav.admin"),
      projects: t("nav.projects"),
      login: t("nav.login"),
      logout: t("nav.logout"),
      toggleMenu: t("nav.toggleMenu"),
      langPtbr: t("lang.pt-br"),
      langEn: t("lang.en"),
      langCurrentPtbr: t("lang.current.pt-br"),
      langCurrentEn: t("lang.current.en"),
    }}
    labels={{
      title: t("issues.title"),
      description: t("issues.description"),
      status: t("issues.status"),
      statusTodo: t("issues.statusTodo"),
      statusInProgress: t("issues.statusInProgress"),
      statusDone: t("issues.statusDone"),
      statusBlocked: t("issues.statusBlocked"),
      statusArchived: t("issues.statusArchived"),
      assignees: t("issues.assignees"),
      addAssignee: t("issues.addAssignee"),
      parentIssue: t("issues.parentIssue"),
      subIssues: t("issues.subIssues"),
      addSubIssue: t("issues.addSubIssue"),
      projects: t("issues.projects"),
      customFields: t("issues.customFields"),
      noDescription: t("issues.noDescription"),
      editDescription: t("issues.editDescription"),
      save: t("issues.save"),
      delete: t("issues.delete"),
      confirmDelete: t("issues.confirmDelete"),
      updated: t("issues.updated"),
      commentsTitle: t("comments.title"),
      commentWrite: t("comments.write"),
      commentSubmit: t("comments.submit"),
      commentEdit: t("comments.edit"),
      commentDelete: t("comments.delete"),
      commentPin: t("comments.pin"),
      commentUnpin: t("comments.unpin"),
      commentPinned: t("comments.pinned"),
      noComments: t("comments.noComments"),
      commentEdited: t("comments.edited"),
    }}
  />
</BaseLayout>
