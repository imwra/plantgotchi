---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav";
import { getLocaleFromPath, useTranslations, loadContent } from "../../i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const prefix = locale === "en" ? "/en" : "";
const helpIndex = await loadContent(locale, "help-index") as any;
---

<BaseLayout title={`${t("help.title")} - Plantgotchi`} description={t("help.subtitle")}>
  <SiteNav
    client:load
    locale={locale}
    currentPath={Astro.url.pathname}
    labels={{
      home: t("nav.home"),
      garden: t("nav.garden"),
      help: t("nav.help"),
      admin: t("nav.admin"),
      login: t("nav.login"),
      logout: t("nav.logout"),
      toggleMenu: t("nav.toggleMenu"),
      langPtbr: t("lang.pt-br"),
      langEn: t("lang.en"),
      langCurrentPtbr: t("lang.current.pt-br"),
      langCurrentEn: t("lang.current.en"),
    }}
  />

  <div class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-xs text-pixel-gray mb-6">
      <a href={`${prefix}/`} class="hover:text-green-dark transition-colors">{t("help.breadcrumb.home")}</a>
      <span class="mx-2">/</span>
      <span class="text-pixel-black">{t("help.breadcrumb.help")}</span>
    </nav>

    <div class="text-center mb-10">
      <h1 class="pixel-font text-base sm:text-lg text-green-dark mb-3">{t("help.title")}</h1>
      <p class="text-sm text-pixel-gray max-w-xl mx-auto">
        {t("help.subtitle")}
      </p>
    </div>

    {helpIndex.categories.map((cat: any) => (
      <section class="mb-10">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-lg">{cat.emoji}</span>
          <h2 class="pixel-font text-[11px] text-pixel-black">{cat.name}</h2>
          <span class="text-xs text-pixel-gray ml-2">{cat.description}</span>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {cat.articles.map((article: any) => (
            <a
              href={`${prefix}/help/${article.slug}`}
              class="block bg-white/60 p-4 pixel-border hover:bg-white/90 transition-colors group"
            >
              <h3 class="text-sm font-bold text-green-dark group-hover:text-green-plant transition-colors mb-1">
                {article.title}
              </h3>
              <p class="text-xs text-pixel-gray leading-relaxed">{article.desc}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
